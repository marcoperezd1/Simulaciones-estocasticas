    {
      "cell_type": "code",
      "source": [
        "fig, ax = plt.subplots(figsize=(9,5))\n",
        "ax.set_xlim(0, T)\n",
        "ax.set_ylim(X.min()-0.5, X.max()+0.5)\n",
        "ax.set_xlabel(\"$t$\")\n",
        "ax.set_ylabel(\"$X_t$\")\n",
        "ax.set_title(\"Animación: Euler-Maruyama (Ornstein-Uhlenbeck)\")\n",
        "\n",
        "line, = ax.plot([], [], lw=1.5, color=\"dodgerblue\")\n",
        "point, = ax.plot([], [], \"o\", color=\"crimson\")\n",
        "\n",
        "steps_per_frame = 10\n",
        "n_frames = N // steps_per_frame   # ¿por qué división entera acá? piénsalo\n",
        "\n",
        "def init():\n",
        "    line.set_data([], [])\n",
        "    point.set_data([], [])\n",
        "    return line, point\n",
        "\n",
        "def update(frame):\n",
        "    idx = (frame + 1) * steps_per_frame                      
        "    line.set_data(t[:idx], X[:idx])\n",
        "    point.set_data([t[idx-1]], [X[idx-1]])  
        "    return line, point\n",
        "\n",
        "ani = animation.FuncAnimation(\n",
        "    fig, update, frames=1000, init_func=init,\n",
        "    blit=True, interval=30\n",
        ")\n",
        "\n",
        "ani.save(\"trayectoria_OU.gif\", writer=\"pillow\", fps=30, dpi = 150)"
      ],
