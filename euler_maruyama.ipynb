      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.animation as animation"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "N = 10000\n",
        "\n",
        "#definimos la semilla\n",
        "seed = 123\n",
        "rng = np.random.default_rng(seed)\n",
        "\n",
        "#definimos la distribución con sus parámetros y el número de samples\n",
        "v = rng.normal(loc= 0, scale = 1, size = N)\n",
        "\n",
        "#media y varianza?\n",
        "print(f\"\\n la media es: {np.mean(v)}\")\n",
        "\n",
        "print(f\"\\n la varianza es: {np.var(v)}\")\n",
        "\n",
        "dt = 0.01\n",
        "\n",
        "#incremento sqrt(dt)N(0, 1), incremento Browniano\n",
        "w = v * np.sqrt(dt)\n",
        "\n",
        "print(f\"\\n la varianza de w es: {np.var(w)}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "gFQ-3GAy8GI0",
        "outputId": "84a3b250-d8dc-4bae-f7dc-e58f36ea990b"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
