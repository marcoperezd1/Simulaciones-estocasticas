    {
      "cell_type": "code",
      "source": [
        "#simulación de una SDE\n",
        "theta = 1.5\n",
        "mu = 0.0\n",
        "sigma = 0.6\n",
        "X0 = 2.0\n",
        "\n",
        "X = np.zeros(N+1)\n",
        "X[0] = X0\n",
        "\n",
        "for n in range(N):\n",
        "  X[n+1] = X[n] + theta * (mu - X[n]) * dt + sigma * dW[n]\n",
        "\n",
        "plt.title(\"Simulación SDE de Ornstein - Uhlenbeck\")\n",
        "plt.xlabel(\"$t$\")\n",
        "plt.ylabel(\"$X_t$\")\n",
        "plt.plot(t, X)\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 472
        },
        "id": "VGd7VkApEWAV",
        "outputId": "3dc55e6f-634c-451f-bc99-1fe8fe1cbb2f"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 640x480 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "theta = 1.5\n",
        "mu = 0.0\n",
        "sigma = 0.6\n",
        "X0 = 2.0\n",
        "\n",
        "media_teorica = X0 * np.exp(-theta*t) + mu*(1 - np.exp(-theta*t))\n",
        "var_teorica = (sigma**2 / (2*theta)) * (1 - np.exp(-2*theta*t))\n",
        "std_teorica = np.sqrt(var_teorica)\n",
        "\n",
        "plt.figure(figsize=(9,5))\n",
        "plt.plot(t, media_teorica, color=\"black\", label=\"Media teórica\")\n",
        "plt.fill_between(t, media_teorica - std_teorica, media_teorica + std_teorica,\n",
        "                  color=\"gray\", alpha=0.3, label=r\"$\\pm 1\\sigma$ teórica\")\n",
        "plt.xlabel(\"$t$\")\n",
        "plt.ylabel(\"$X_t$\")\n",
        "plt.title(\"Solución teórica del proceso de Ornstein-Uhlenbeck\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
      "metadata": {
