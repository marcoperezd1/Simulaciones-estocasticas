            "\n",
            " la media es: 0.008237681580652776\n",
            "\n",
            " la varianza es: 0.9930349516533333\n",
            "\n",
            " la varianza de w es: 0.009930349516533335\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#construcción del camino Browniano\n",
        "dW = np.sqrt(dt) * v #incremento\n",
        "W = np.insert(np.cumsum(dW), 0, 0) # camino a partir de la suma de incrementos iid\n",
        "print(W)"
      ],
      "metadata": {
        "colab": {
