    {
      "cell_type": "code",
      "source": [
        "X_exacta = np.zeros(N + 1)\n",
        "X_exacta[0] = X0\n",
        "\n",
        "\n",
        "for n in range(N):\n",
        "  media_cond = X_exacta[n]*np.exp(-theta*dt) + mu*(1-np.exp(-theta*dt))\n",
        "  std_cond = np.sqrt( sigma**2/(2*theta) * (1-np.exp(-2*theta*dt)))\n",
        "  X_exacta[n+1] = media_cond + std_cond * v[n]\n",
        "\n",
        "plt.title(\"Solución exacta de Ornstein - Uhlenbeck\")\n",
        "plt.xlabel(\"$t$\")\n",
        "plt.ylabel(\"$X_t$\")\n",
        "plt.plot(t, X_exacta)\n",
        "plt.show()"
      ],
