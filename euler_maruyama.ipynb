            "[ 0.         -0.09891214 -0.1356908  ...  8.35179298  8.20433368\n",
            "  8.23768158]\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "T = N * dt #tiempo final\n",
        "t = np.linspace(0, T, N+1) #intervalo temporal [0,T]\n",
        "\n",
        "\n",
        "plt.plot(t, W)\n",
        "plt.title(\"Trayectoria movimiento Browniano\")\n",
        "plt.xlabel(\"$t$\")\n",
        "plt.ylabel(\"$W_t$\")\n"
      ],
      "metadata": {
