    {
      "cell_type": "code",
      "source": [
        "rng = np.random.default_rng(123)\n",
        "n_trayectorias = 5\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9,5))\n",
        "\n",
        "for i in range(n_trayectorias):\n",
        "    v = rng.normal(0, 1, N)\n",
        "    dW = np.sqrt(dt) * v\n",
        "    W = np.insert(np.cumsum(dW), 0, 0)\n",
        "    ax.plot(t, W, alpha=0.6)\n",
        "\n",
        "ax.plot(t, np.sqrt(t), \"--\", color=\"black\", label=r\"$\\pm\\sqrt{t}$\")\n",
        "ax.plot(t, -np.sqrt(t), \"--\", color=\"black\")\n",
        "ax.set_xlabel(\"Tiempo $t$\")\n",
        "ax.set_ylabel(\"$W_t$\")\n",
        "ax.set_title(\"Trayectorias de un movimiento browniano estándar\")\n",
        "ax.legend()\n",
        "plt.show()"
      ],
