        "plt.xlabel(\"$t$\")\n",
        "plt.ylabel(\"$X_t$\")\n",
        "plt.title(\"Euler-Maruyama vs. solución teórica (Ornstein-Uhlenbeck)\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
