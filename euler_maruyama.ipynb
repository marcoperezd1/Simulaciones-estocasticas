        "media_teorica = X0 * np.exp(-theta*t) + mu*(1 - np.exp(-theta*t))\n",
        "var_teorica = (sigma**2 / (2*theta)) * (1 - np.exp(-2*theta*t))\n",
        "std_teorica = np.sqrt(var_teorica)\n",
        "\n",
        "plt.figure(figsize=(9,5))\n",
        "plt.plot(t, X, label=\"Euler-Maruyama (simulación)\")\n",
        "plt.plot(t, media_teorica, \"--\", color=\"black\", label=\"Media teórica\")\n",
